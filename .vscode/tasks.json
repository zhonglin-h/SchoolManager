{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Gradle Build",
      "type": "shell",
      "command": "${workspaceFolder:SchoolManager}/backend/gradlew",
      "args": ["build", "-p", "${workspaceFolder:SchoolManager}/backend"],
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": "$javac"
    },
    {
      "label": "Backend: Run Tests",
      "type": "shell",
      "command": "${workspaceFolder:SchoolManager}/backend/gradlew",
      "args": ["test", "-p", "${workspaceFolder:SchoolManager}/backend"],
      "group": "test",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": "$javac"
    },
    {
      "label": "Frontend: Install",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder:SchoolManager}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Frontend: Dev Server",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder:SchoolManager}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder:SchoolManager}/frontend"
      },
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
